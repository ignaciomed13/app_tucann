# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini (server-side only, never exposed to the client)
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Web Push (VAPID) — generar con: node scripts/generate-vapid.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron de recordatorios (server-side, nunca al cliente)
# SUPABASE_SERVICE_ROLE_KEY: Supabase -> Settings -> API -> service_role (SECRETO)
SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET: string aleatorio; protege /api/cron/reminders
CRON_SECRET=

# Admin: user_id (uuid de Supabase Auth) que puede moderar sugerencias de
# socios en /dashboard/socios/revision. Sin esto, no hay admin.
ADMIN_USER_ID=
